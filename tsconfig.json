{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ESNext", "DOM"],
    "strict": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noEmit": true,
    "types": [
      "@league-of-foundry-developers/foundry-vtt-types",
      "handlebars"
    ]
  },
  "include": ["src/**/*"]
}