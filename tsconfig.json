{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "strict": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noEmit": true,
    "types": ["@league-of-foundry-developers/foundry-vtt-types"],
    "baseUrl": ".",
    "paths": {
      "@dnd5e/*": ["./external-dts/dnd5e/*"],
      "@tidy5e/*": ["./external-dts/tidy-5e/*"]
    },
    "allowJs": true
  },
  "include": ["src/**/*"],
  "exclude": ["externals/tidy-5e/**"]
}
