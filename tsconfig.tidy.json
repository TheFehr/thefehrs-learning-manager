{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "strict": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowJs": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "types": ["@league-of-foundry-developers/foundry-vtt-types"],
    "outDir": "./external-dts/tidy-5e",
    "baseUrl": "./externals/tidy-5e",
    "paths": {
      "@tidy5e/*": ["./src/*"],
      "src/*": ["./src/*"]
    }
  },
  "include": ["src/**/*.ts", "../../src/svelte-shims.d.ts"],
  "exclude": ["src/**/*.svelte.ts"]
}
