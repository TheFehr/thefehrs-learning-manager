<div class="thefehrs-settings">
  <div style="display:flex; justify-content:space-between; margin-bottom:15px;">
    <button type="button" data-action="exportData" style="width:48%;"><i
        class="fas fa-file-export"
      ></i>
      Export JSON
    </button>
    <button type="button" data-action="importData" style="width:48%;"><i
        class="fas fa-file-import"
      ></i>
      Import JSON
    </button>
  </div>

  <h3>Global Rules</h3>
  <div class="form-group"><label>Method:</label>
    <select name="rules.method">
      {{selectOptions choices selected=rules.method}}
    </select>
  </div>
  <div class="form-group"><label>Check Formula:</label><input
      type="text"
      name="rules.checkFormula"
      value="{{rules.checkFormula}}"
    /></div>
  <div class="form-group"><label>Check DC:</label><input
      type="number"
      name="rules.checkDC"
      value="{{rules.checkDC}}"
    />
  </div>
  <div class="form-group"><label>Crit Double Strategy:</label>
    <select name="rules.critDoubleStrategy">
      {{selectOptions critStrategies selected=rules.critDoubleStrategy}}
    </select>
  </div>
  <div class="form-group"><label>Crit Double Threshold:</label><input
      type="number"
      name="rules.critThreshold"
      value="{{rules.critThreshold}}"
      placeholder="e.g., 20"
    />
  </div>
  <hr />

  <h3>Time Units</h3>
  <table class="tidy-table" style="font-size:0.8rem;">
    <tr>
      <th>Name</th>
      <th>Short</th>
      <th>Ratio</th>
      <th>Bulk Method?</th>
      <th></th>
    </tr>
    {{#each timeUnits}}
      <tr>
        <td><input type="text" name="timeUnits.{{id}}.name" value="{{name}}" /></td>
        <td><input
            type="text"
            name="timeUnits.{{id}}.short"
            value="{{short}}"
            style="width:40px;"
          /></td>
        <td><input type="number" name="timeUnits.{{id}}.ratio" value="{{ratio}}" min="1" /></td>
        <td><input type="checkbox" name="timeUnits.{{id}}.isBulk" {{checked isBulk}} /></td>
        <td>
          <input type="hidden" name="timeUnits.{{id}}.id" value="{{id}}" />
          <button type="button" data-action="deleteTimeUnit" data-id="{{id}}"><i
              class="fas fa-trash"
            ></i>
          </button>
        </td>
      </tr>
    {{/each}}
  </table>
  <button type="button" data-action="addTimeUnit" style="margin-top:5px;"><i
      class="fas fa-plus"
    ></i>
    Add Time Unit
  </button>
  <hr />

  <h3>Guidance Tiers (The Matrix)</h3>
  <div class="table-responsive-wrapper">
    <table class="tidy-table" style="font-size:0.8rem;">
      <thead>
        <tr>
          <th>Tier Name</th>
          <th>Roll Mod</th>
          {{#each timeUnits}}
            <th title="Cost per {{name}} in cp">Cost/{{short}} (cp)</th>
            {{#if isBulk}}
              <th title="Progress gained per {{name}}">Prog/{{short}}</th>{{/if}}
          {{/each}}
          <th></th>
        </tr>
      </thead>
      <tbody>
        {{#each this.tiers as |tier|}}
          <tr>
            <td><input type="text" name="tiers.{{tier.id}}.name" value="{{tier.name}}" /></td>
            <td><input
                type="number"
                name="tiers.{{tier.id}}.modifier"
                value="{{tier.modifier}}"
              /></td>
            <input type="hidden" name="tiers.{{tier.id}}.id" value="{{tier.id}}" />
            {{#each @root.timeUnits as |timeUnit|}}
              <td><input
                  type="number"
                  name="tiers.{{tier.id}}.costs.{{timeUnit.id}}"
                  value="{{lookup tier.costs timeUnit.id}}"
                  step="1"
                /></td>
              {{#if timeUnit.isBulk}}
                <td><input
                    type="number"
                    name="tiers.{{tier.id}}.progress.{{timeUnit.id}}"
                    value="{{lookup tier.progress timeUnit.id}}"
                  /></td>{{/if}}
            {{/each}}
            <td>
              <button type="button" data-action="deleteTier" data-id="{{tier.id}}"><i
                  class="fas fa-trash"
                ></i>
              </button>
            </td>
          </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
  <button type="button" data-action="addTier" style="margin-top:5px;"><i class="fas fa-plus"></i>
    Add Tier
  </button>
  <hr />
  <h3>Project Library</h3>
  <table class="tidy-table">
    <tr>
      <th>Project Name</th>
      <th>Requirements (Path / Operator / Value)</th>
      <th>Target Base Units</th>
      <th>Reward Type</th>
      <th title="Paste an Item or Effect UUID here to auto-grant it upon completion">Reward UUID</th>
      <th></th>
    </tr>
    {{#each projects as |project|}}
      <tr>
        <td style="vertical-align: top;"><input
            type="text"
            name="projects.{{project.id}}.name"
            value="{{project.name}}"
          /></td>
        <td style="min-width: 320px; vertical-align: top;">
          {{#each project.requirements as |req|}}
            <div style="display:flex; gap: 4px; margin-bottom: 5px; align-items: center;">
              <input
                type="text"
                name="projects.{{project.id}}.requirements.{{req.id}}.attribute"
                value="{{req.attribute}}"
                placeholder="system.abilities.int.value"
                style="flex: 2; font-family: monospace; font-size: 0.8em;"
                title="Attribute Path"
              />
              <select
                name="projects.{{project.id}}.requirements.{{req.id}}.operator"
                style="flex: 1;"
                title="Comparison Operator"
              >
                {{selectOptions @root.operatorChoices selected=req.operator}}
              </select>
              <input
                type="text"
                name="projects.{{project.id}}.requirements.{{req.id}}.value"
                value="{{req.value}}"
                placeholder="14"
                style="flex: 1;"
                title="Target Value"
              />

              <button
                type="button"
                data-action="deleteRequirement"
                data-project-id="{{project.id}}"
                data-req-id="{{req.id}}"
                style="flex: 0 0 25px;"
                title="Remove Requirement"
              ><i class="fas fa-trash"></i></button>
              <input
                type="hidden"
                name="projects.{{project.id}}.requirements.{{req.id}}.id"
                value="{{req.id}}"
              />
            </div>
          {{/each}}
          <button
            type="button"
            data-action="addRequirement"
            data-project-id="{{project.id}}"
            class="tidy-button small"
          ><i class="fas fa-plus"></i>
            Add Requirement
          </button>
        </td>
        <td style="vertical-align: top;"><input
            type="number"
            name="projects.{{project.id}}.target"
            value="{{project.target}}"
            min="1"
          /></td>
        <td style="vertical-align: top;">
          <select name="projects.{{project.id}}.rewardType">
            {{selectOptions @root.rewardTypes selected=project.rewardType}}
          </select>
        </td>
        <td style="vertical-align: top;"><input
            type="text"
            name="projects.{{project.id}}.rewardUuid"
            value="{{project.rewardUuid}}"
            placeholder="Paste Item or Effect UUID"
          /></td>
        <td style="vertical-align: top;">
          <input type="hidden" name="projects.{{project.id}}.id" value="{{project.id}}" />
          <button type="button" data-action="deleteProject" data-id="{{project.id}}"><i
              class="fas fa-trash"
            ></i>
          </button>
        </td>
      </tr>
    {{/each}}
  </table>
  <button type="button" data-action="addProject" style="margin-top:5px;"><i class="fas fa-plus"></i>
    Add Project
  </button>
</div>