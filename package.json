{
  "name": "thefehrs-learning-manager",
  "version": "1.3.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "fmt": "oxfmt --no-error-on-unmatched-pattern",
    "fmt:check": "oxfmt --check",
    "lint:hbs": "./scripts/check-hbs-syntax.sh",
    "test": "vitest run",
    "release": "release-it",
    "prepare": "husky"
  },
  "devDependencies": {
    "@league-of-foundry-developers/foundry-vtt-types": "^13.345.1",
    "@release-it/bumper": "^7.0.5",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@types/handlebars": "^4.0.40",
    "happy-dom": "^20.8.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "oxfmt": "^0.36.0",
    "release-it": "^19.2.4",
    "sass-embedded": "^1.97.3",
    "svelte": "^5.54.0",
    "typescript": "^5.0.0",
    "vite": "^7.3.1",
    "vite-plugin-fvtt": "latest",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "**/*.hbs": "npm run lint:hbs",
    "**/*.{ts,json,js,hbs,scss,md}": "npm run fmt"
  }
}
