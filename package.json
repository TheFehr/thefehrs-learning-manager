{
  "name": "thefehrs-learning-manager",
  "version": "2.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "generate-types": "node scripts/generate-external-types.mjs",
    "build": "tsc && vite build",
    "fmt": "oxfmt --no-error-on-unmatched-pattern",
    "fmt:check": "oxfmt --check",
    "test": "vitest run",
    "release": "release-it",
    "prepare": "husky"
  },
  "devDependencies": {
    "@league-of-foundry-developers/foundry-vtt-types": "^13.345.1",
    "@release-it/bumper": "^7.0.5",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "happy-dom": "^20.8.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "oxfmt": "^0.42.0",
    "release-it": "^19.2.4",
    "sass-embedded": "^1.97.3",
    "svelte": "^5.20.0",
    "typescript": "^6.0.0",
    "vite": "^8.0.1",
    "vitest": "^4.1.0"
  },
  "lint-staged": {
    "**/*.{ts,json,js,scss,md,mjs,yml}": "npm run fmt"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
